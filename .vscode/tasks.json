{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Django Backend",
      "type": "shell",
      "command": ".venv\\Scripts\\python manage.py runserver",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "group": "servers",
        "reveal": "always",
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run Next.js Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/nexara-site"
      },
      "presentation": {
        "group": "servers",
        "reveal": "always",
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Run Fullstack App",
      "dependsOn": [
        "Run Django Backend",
        "Run Next.js Frontend"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
